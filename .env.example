# --- DATABASE CONFIGURATION ---
# Option 1: Local PostgreSQL via Docker (default for docker-compose deployment)
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@db:5432/checkhost?schema=public"
POSTGRES_DB="checkhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="YOUR_STRONG_PASSWORD"

# Option 2: Supabase (for external managed DB)
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# ------------------------------

# Authentication (REQUIRED)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://yourdomain.com"

# Google OAuth (optional, for Google SSO login)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin Emails (comma separated — these users get admin role on first login)
ADMIN_EMAILS="admin@yourdomain.com"

# Traditional Admin Credentials (email/password login)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="YOUR_STRONG_ADMIN_PASSWORD"

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXXXXXXXX"

# Site Info (used for metadata and SEO)
NEXT_PUBLIC_SITE_URL="https://checknode.io"
NEXT_PUBLIC_SITE_NAME="checknode.io"

# CheckHost API (backend checks — do not change unless self-hosting)
CHECKHOST_API_URL="https://check-host.net"

# AI Features (optional — for auto-blogger)
GEMINI_API_KEY="your-gemini-api-key"

# IP Info API (optional — for IP geolocation fallback)
IPINFO_TOKEN="your-ipinfo-token"

# Cron Security (REQUIRED for automated blog generation/publishing)
# Generate a strong secret: openssl rand -base64 32
CRON_SECRET="your-cron-secret-key"
